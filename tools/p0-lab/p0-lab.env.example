# p0-lab.env — configuration for the P0 lab automation (tools/p0-lab/).
# Copy to p0-lab.env and fill in. This file is git-ignored; NEVER put passwords
# here. Credentials live ONLY in separate 0400 files, referenced by PATH below.
#
#   cp p0-lab.env.example p0-lab.env && $EDITOR p0-lab.env
#
# ── Targets (non-secret identifiers) ────────────────────────────────────────
# Windows host with RDP + NLA (OPERATOR PROVIDES — no mock is ever used).
P0_WIN_TARGET=""              # e.g. 10.20.0.10  (or 10.20.0.10:3389)
P0_WIN_USER=""               # e.g. LAB\\labuser
# Linux xrdp host — can be auto-provisioned by 40-xrdp-target.sh, or set manually.
P0_XRDP_TARGET=""            # e.g. 172.30.0.5:3389  (filled by 40-xrdp-target.sh)
P0_XRDP_USER="labuser"
P0_RDP_PORT="3389"

# ── Credentials (PATHS to 0400 files — never inline the secret) ─────────────
# Create like:  umask 077; printf '%s' 'the-password' > cred.valid; chmod 0400 cred.valid
P0_CRED_VALID_FILE=""        # valid password, 0400, owned by you
P0_CRED_INVALID_FILE=""      # deliberately wrong password, 0400 (auth_reject)
# xrdp container test password (0400) — consumed by 40-xrdp-target.sh, never logged.
P0_XRDP_CRED_FILE=""

# ── Certificates / CA (auto-generated by 30-make-ca.sh unless you set these) ─
P0_CA_DIR=""                 # default: tools/p0-lab/ca
P0_XRDP_CN=""                # server cert CN; default derives from P0_XRDP_TARGET
# For the TRUSTED cert scenario, point the worker's trust store at the lab CA:
#   export SSL_CERT_FILE="$P0_CA_DIR/lab-ca.crt"     (host-native run), or mount it read-only in the container.

# ── xrdp container (40-xrdp-target.sh) ──────────────────────────────────────
# Use a trusted, PINNED-BY-DIGEST xrdp image you have vetted. Not auto-pulled.
P0_XRDP_IMAGE=""             # e.g. myregistry/xrdp@sha256:...
P0_LAB_NET="p0-lab-net"
P0_XRDP_CONTAINER="p0-xrdp"

# ── Allowlist / egress ──────────────────────────────────────────────────────
P0_ALLOWLIST=""              # optional explicit addr:port; else derived per scenario

# ── Run tuning ──────────────────────────────────────────────────────────────
P0_BASELINE_COUNT="20"       # sequential connects for the CPU/RAM/latency baseline
