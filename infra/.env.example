# Copie para .env e ajuste. Nunca commitar o .env.
POSTGRES_USER=pam
POSTGRES_PASSWORD=troque-esta-senha-local
POSTGRES_DB=pam

# Senha do asset VNC de laboratorio (max. 8 chars — limite do VNC Authentication)
LAB_VNC_PASSWORD=labonly1

# Segredo para assinar o cookie de sessao do portal (>=16 chars). Gere um novo:
#   openssl rand -base64 32
COOKIE_SECRET=troque-por-um-segredo-longo-e-aleatorio

# URL publica do gateway (WSS) que o backend devolve ao frontend.
GATEWAY_PUBLIC_URL=wss://localhost/gateway/vnc

# Cookie 'secure' — mantenha true (nginx termina TLS). Use false apenas se
# acessar o backend direto por http em dev.
SECURE_COOKIE=true

# Master key do cofre interino (AES-256-GCM) — 32 bytes em base64. IDENTICA no
# backend e no gateway. Nunca commitar. Gere com:
#   openssl rand -base64 32
CREDENTIAL_MASTER_KEY=troque-por-32-bytes-em-base64

# Provider de credencial: enc (AES-GCM, default) | vault (HashiCorp Vault).
# Com 'vault', o serviço vault (dev) do compose é usado; VAULT_TOKEN é o root
# token de dev. Em produção: storage persistente + AppRole.
CREDENTIAL_PROVIDER=enc
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root
VAULT_KV_MOUNT=secret

# Rate limit (por minuto)
RATE_LIMIT_LOGIN_PER_MIN=5
RATE_LIMIT_SESSION_PER_MIN=10
