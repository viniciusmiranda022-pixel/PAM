# Copie para .env e ajuste. Nunca commitar o .env.
POSTGRES_USER=pam
POSTGRES_PASSWORD=troque-esta-senha-local
POSTGRES_DB=pam

# Senha do asset VNC de laboratorio (max. 8 chars — limite do VNC Authentication)
LAB_VNC_PASSWORD=labonly1

# Segredo para assinar o cookie de sessao do portal (>=16 chars). Gere um novo:
#   openssl rand -base64 32
COOKIE_SECRET=troque-por-um-segredo-longo-e-aleatorio

# URL publica do gateway (WSS) que o backend devolve ao frontend.
GATEWAY_PUBLIC_URL=wss://localhost/gateway/vnc

# Cookie 'secure' — mantenha true (nginx termina TLS). Use false apenas se
# acessar o backend direto por http em dev.
SECURE_COOKIE=true
