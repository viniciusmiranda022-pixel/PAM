# Copie para .env e ajuste. Nunca commitar o .env.
POSTGRES_USER=pam
POSTGRES_PASSWORD=troque-esta-senha-local
POSTGRES_DB=pam

# Senha do asset VNC de laboratorio (max. 8 chars — limite do VNC Authentication)
LAB_VNC_PASSWORD=labonly1

# Senhas do seed de laboratorio (usuarios `poc` e `admin`). OBRIGATORIAS para
# rodar o seed — nao existem defaults e o seed nao imprime senha (HR-06).
SEED_USER_PASSWORD=defina-uma-senha-forte
SEED_ADMIN_PASSWORD=defina-outra-senha-forte

# Opcional: senha da role de runtime `pam_app` (privilegio minimo; auditoria
# append-only). Se definida ANTES do 1o boot do postgres, a role e criada e
# voce pode apontar DATABASE_URL para ela. Vazio = app usa o dono do banco.
#PAM_APP_PASSWORD=

# Segredo para assinar o cookie de sessao do portal (>=16 chars). Gere um novo:
#   openssl rand -base64 32
COOKIE_SECRET=troque-por-um-segredo-longo-e-aleatorio

# URL publica do gateway (WSS) que o backend devolve ao frontend.
GATEWAY_PUBLIC_URL=wss://localhost/gateway/vnc

# Cookie 'secure' — mantenha true (nginx termina TLS). Use false apenas se
# acessar o backend direto por http em dev.
SECURE_COOKIE=true

# Master key do cofre interino (AES-256-GCM) — 32 bytes em base64. IDENTICA no
# backend e no gateway. Nunca commitar. Gere com:
#   openssl rand -base64 32
CREDENTIAL_MASTER_KEY=troque-por-32-bytes-em-base64

# Provider de credencial: enc (AES-GCM, default) | vault (HashiCorp Vault).
# Com 'vault', o serviço vault (dev) do compose é usado; VAULT_TOKEN é o root
# token de dev. Em produção: storage persistente + AppRole.
CREDENTIAL_PROVIDER=enc
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root
VAULT_KV_MOUNT=secret

# Rate limit (por minuto)
RATE_LIMIT_LOGIN_PER_MIN=5
RATE_LIMIT_SESSION_PER_MIN=10

# ── Auth enterprise (PR-15) — todos opcionais ────────────────────────────────
# OIDC (ADFS 2019+, Entra ID, Keycloak, Auth0…). Definindo ISSUER/CLIENT_ID/
# CLIENT_SECRET/REDIRECT_URI, o botao SSO aparece (Authorization Code + PKCE).
#OIDC_ISSUER=https://idp.example.com/realms/pam
#OIDC_CLIENT_ID=pam-portal
#OIDC_CLIENT_SECRET=troque
#OIDC_REDIRECT_URI=https://pam.example.com/api/v1/auth/oidc/callback
#OIDC_AUTO_PROVISION=true
#OIDC_TOKEN_AUTH=post          # post (default) | basic (alguns ADFS)
#OIDC_GROUPS_CLAIM=groups      # claim que carrega os grupos do IdP
#OIDC_ADMIN_GROUP=PAM-Admins   # grupo do IdP que ELEVA a admin (nunca rebaixa)
#OIDC_PROVIDER_LABEL=Entra ID

# SAML 2.0 (ADFS legado / Shibboleth). SAML_IDP_CERT e o certificado publico do
# IdP (PEM/base64) usado para validar a assinatura da assercao.
#SAML_IDP_ENTRYPOINT=https://adfs.example.com/adfs/ls/
#SAML_IDP_CERT=MIIC...   # certificado do token-signing do ADFS
#SAML_SP_ISSUER=https://pam.example.com/saml/metadata
#SAML_CALLBACK_URL=https://pam.example.com/api/v1/auth/saml/callback
#SAML_AUTO_PROVISION=true
#SAML_ADMIN_GROUP=PAM-Admins
#SAML_PROVIDER_LABEL=SSO corporativo
